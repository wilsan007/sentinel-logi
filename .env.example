# =============================================
# Variables d'environnement Lovable Cloud
# =============================================
# Copiez ce fichier en .env et remplissez les valeurs.
# En projet Lovable, ces variables sont injectées automatiquement
# par la plateforme — ne committez JAMAIS de vraies valeurs.

# URL publique du backend (Lovable Cloud / Supabase)
VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"

# Clé publique anon (publishable) — sûre côté client si RLS bien configuré
VITE_SUPABASE_PUBLISHABLE_KEY="<your-anon-key>"

# Identifiant du projet
VITE_SUPABASE_PROJECT_ID="<your-project-ref>"

# =============================================
# Optionnel — Observabilité
# =============================================
# DSN public Sentry pour la capture d'erreurs côté client
# VITE_SENTRY_DSN="https://<key>@sentry.io/<project>"
# VITE_SENTRY_ENVIRONMENT="production"
